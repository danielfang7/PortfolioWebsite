---
const year = new Date().getFullYear();

const socialLinks = [
  { label: "GitHub", href: "https://github.com/danielfang", icon: "github" },
  { label: "LinkedIn", href: "https://linkedin.com/in/danielfang", icon: "linkedin" },
  { label: "X / Twitter", href: "https://twitter.com/danielfang", icon: "x" },
];
---

<footer class="border-t border-border-subtle section-padding" aria-label="Site footer">
  <div class="container-content">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex flex-col items-center md:items-start gap-1">
        <span class="font-display font-bold text-text-primary">Daniel Fang</span>
        <span class="text-sm text-text-muted">
          &copy; {year} — Built with Astro &amp; GSAP
        </span>
      </div>

      <nav aria-label="Social links">
        <ul class="flex items-center gap-5" role="list">
          {
            socialLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors duration-200"
                  aria-label={`${label} (opens in new tab)`}
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</footer>
