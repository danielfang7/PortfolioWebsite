---
const socialLinks = [
  {
    label: "GitHub",
    href: "https://github.com/danielfang7",
    ariaLabel: "GitHub profile (opens in new tab)",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/danielfang7",
    ariaLabel: "LinkedIn profile (opens in new tab)",
  },
  {
    label: "X",
    href: "https://twitter.com/danielfang7",
    ariaLabel: "X / Twitter profile (opens in new tab)",
  },
];
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden"
  aria-label="Introduction"
>
  <!-- Subtle background grid -->
  <div class="absolute inset-0 bg-grid-pattern opacity-[0.03] pointer-events-none" aria-hidden="true" />

  <!-- Accent glow -->
  <div
    class="absolute top-1/3 left-1/4 w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(108,99,255,0.06) 0%, transparent 70%); transform: translate(-50%, -50%);"
    aria-hidden="true"
  />

  <div class="container-content relative z-10 pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-12 lg:gap-16">
      <div class="max-w-2xl flex-shrink-0">
        <!-- Eyebrow -->
        <div id="hero-eyebrow" class="anim-fade-up mb-6 flex items-center gap-3">
          <span class="accent-line" aria-hidden="true" />
          <span class="text-sm font-medium tracking-widest text-accent uppercase">
            Founder, Engineer, Investor
          </span>
        </div>

        <!-- Headline -->
        <h1
          id="hero-headline"
          class="anim-fade-up font-display text-display-md font-bold text-text-primary text-balance mb-6"
          style="animation-delay: 100ms;"
        >
          Building is my passion.
          <br />
          <em class="not-italic gradient-text">Inspiration keeps me building.</em>
        </h1>

        <!-- Subtext -->
        <p
          id="hero-subtext"
          class="anim-fade-up text-base md:text-lg text-text-secondary max-w-lg leading-relaxed mb-10"
          style="animation-delay: 200ms;"
        >
          YC Founder & Angel Investor. I design and engineer products and systems, angel
          invest in companies (pre-Seed to Seed), and have a variety of random interest and hobbies. 
        </p>

        <!-- CTAs + Social links -->
        <div
          id="hero-actions"
          class="anim-fade-up flex flex-wrap items-center gap-6"
          style="animation-delay: 300ms;"
        >
        <a
          href="/works"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-white font-semibold text-sm tracking-wide hover:bg-accent-hover transition-all duration-200 ease-out-expo hover:-translate-y-px hover:shadow-lg hover:shadow-accent/20"
        >
          View Works
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>

        <nav aria-label="Social media links">
          <ul class="flex items-center gap-4" role="list">
            {
              socialLinks.map(({ label, href, ariaLabel }) => (
                <li>
                  <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={ariaLabel}
                    class="text-sm text-text-secondary hover:text-text-primary transition-colors duration-200 relative group"
                  >
                    {label}
                    <span class="absolute -bottom-0.5 left-0 h-px w-0 bg-accent transition-all duration-300 ease-out-expo group-hover:w-full" aria-hidden="true" />
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
      </div>

      <!-- Hero image -->
      <div
        id="hero-image"
        class="anim-fade-up flex-shrink-0 lg:w-[380px] xl:w-[420px] order-first lg:order-last"
        style="animation-delay: 150ms;"
      >
        <img
          src="/Fang_Daniel_114-PilotSF-1471%20-%20use.jpg"
          alt="Daniel Fang"
          class="rounded-2xl w-full aspect-[3/4] object-cover shadow-2xl shadow-black/40"
          width="420"
          height="560"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    id="hero-scroll-cue"
    class="anim-fade-in absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
    style="animation-delay: 800ms;"
    aria-hidden="true"
  >
    <span class="text-xs tracking-widest text-text-muted uppercase">Scroll</span>
    <div class="w-px h-10 scroll-line bg-border relative overflow-hidden">
      <span class="scroll-shimmer absolute inset-0 bg-gradient-to-b from-transparent via-accent to-transparent" />
    </div>
  </div>
</section>

<style>
  .bg-grid-pattern {
    background-image:
      linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .scroll-shimmer {
    animation: shimmerDown 2s ease-in-out infinite;
  }

  @keyframes shimmerDown {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }

  /* Hidden by CSS before JS runs — prevents the paint→hide flash.
     GSAP animates these to opacity:1. The noscript block below
     overrides this for users with JS disabled. */
  #hero-eyebrow,
  #hero-headline,
  #hero-subtext,
  #hero-actions,
  #hero-image,
  #hero-scroll-cue {
    opacity: 0;
  }
</style>

<noscript>
  <style>
    #hero-eyebrow,
    #hero-headline,
    #hero-subtext,
    #hero-actions,
    #hero-image,
    #hero-scroll-cue {
      opacity: 1 !important;
    }
  </style>
</noscript>

<script>
  import { gsap } from "gsap";

  const HERO_IDS = "#hero-eyebrow, #hero-headline, #hero-subtext, #hero-actions, #hero-image, #hero-scroll-cue";

  function initHero() {
    const hero = document.getElementById("hero");
    if (!hero) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (prefersReducedMotion) {
      // Skip animation but ensure elements are visible (CSS hides them by default)
      gsap.set(HERO_IDS, { opacity: 1, y: 0 });
      return;
    }

    // CSS already sets opacity:0 on these elements before first paint so there
    // is no flash. gsap.set() locks in the starting y offsets synchronously,
    // then the timeline animates everything into place.
    gsap.set("#hero-eyebrow",    { y: 20 });
    gsap.set("#hero-headline",   { y: 30 });
    gsap.set("#hero-subtext",    { y: 24 });
    gsap.set("#hero-actions",    { y: 20 });
    gsap.set("#hero-image",      { y: 24 });

    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
    tl.to("#hero-eyebrow",    { opacity: 1, y: 0, duration: 0.7 })
      .to("#hero-headline",   { opacity: 1, y: 0, duration: 0.8 }, "-=0.4")
      .to("#hero-subtext",    { opacity: 1, y: 0, duration: 0.7 }, "-=0.5")
      .to("#hero-actions",    { opacity: 1, y: 0, duration: 0.6 }, "-=0.4")
      .to("#hero-image",      { opacity: 1, y: 0, duration: 0.8 }, "-=1.2")
      .to("#hero-scroll-cue", { opacity: 1,        duration: 0.8 },  "-=0.1");
  }

  let _heroFired = false;
  document.addEventListener("astro:page-load", () => {
    _heroFired = true;
    initHero();
  });
  requestAnimationFrame(() => {
    if (!_heroFired) initHero();
  });
</script>
