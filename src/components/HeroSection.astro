---
import { HeroParticleField } from "@/components/HeroParticleField";

const socialLinks = [
  {
    label: "GitHub",
    href: "https://github.com/danielfang7",
    ariaLabel: "GitHub profile (opens in new tab)",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/danielfang7",
    ariaLabel: "LinkedIn profile (opens in new tab)",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: "X",
    href: "https://twitter.com/danielfang7",
    ariaLabel: "X / Twitter profile (opens in new tab)",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<section
  id="hero"
  class="relative min-h-screen max-h-[1100px] flex flex-col justify-center overflow-hidden"
  aria-label="Introduction"
>
  <!-- Particle field background (hidden on mobile for performance) -->
  <div
    class="absolute inset-0 pointer-events-none hidden md:block hero-particle-mask"
    aria-hidden="true"
  >
    <HeroParticleField client:idle />
  </div>

  <!-- Accent glow -->
  <div
    class="absolute top-1/3 left-1/4 w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(108,99,255,0.04) 0%, transparent 70%); transform: translate(-50%, -50%);"
    aria-hidden="true"
  />

  <div class="container-content relative z-10 pt-28 pb-10 md:pt-36 md:pb-14">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-12 lg:gap-16">
      <div class="max-w-2xl flex-shrink-0">
        <!-- Eyebrow -->
        <div id="hero-eyebrow" class="anim-fade-up mb-6 flex items-center gap-3">
          <span class="accent-line" aria-hidden="true" />
          <span class="text-sm font-medium tracking-widest text-accent uppercase">
            Founder (YC Alumni), Engineer, Investor
          </span>
        </div>

        <!-- Headline -->
        <h1
          id="hero-headline"
          class="anim-fade-up font-display text-display-md font-bold text-text-primary text-balance mb-6"
          style="animation-delay: 100ms;"
        >
          <em class="not-italic gradient-text"> Stay inspired and keep building. </em>
        </h1>

        <!-- Subtext -->
        <p
          id="hero-subtext"
          class="anim-fade-up text-base md:text-lg text-text-secondary max-w-lg leading-relaxed mb-10"
          style="animation-delay: 200ms;"
        >
          I've built AI developer tools, full stack web apps, and high-end multiplayer games from 0 to 1, with experience leading GTM, fundraising, and all other startup operations. I also angel
          invest in early stage companies. 
        </p>

        <!-- CTAs + Social links -->
        <div
          id="hero-actions"
          class="anim-fade-up flex flex-col gap-4"
          style="animation-delay: 300ms;"
        >
          <!-- Primary buttons -->
          <div class="flex flex-wrap items-center gap-4">
            <a
              href="/works"
              data-magnetic
              class="magnetic-cta inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-white font-semibold text-sm tracking-wide hover:bg-accent-hover transition-colors duration-200 ease-out-expo hover:shadow-lg hover:shadow-accent/20"
            >
              <span class="magnetic-cta__inner inline-flex items-center gap-2">
                View Works
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </a>
            <a
              href="/investments"
              data-magnetic
              class="magnetic-cta inline-flex items-center justify-center px-6 py-3 rounded-lg border border-accent/40 text-accent font-semibold text-sm tracking-wide hover:border-accent hover:bg-accent/10 transition-colors duration-200 ease-out-expo"
            >
              <span class="magnetic-cta__inner inline-flex items-center gap-2">
                View Investments
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </a>
          </div>

          <!-- Social icon links -->
          <nav aria-label="Social media links">
            <ul class="flex items-center gap-3" role="list">
              {
                socialLinks.map(({ label, href, ariaLabel, icon }) => (
                  <li>
                    <a
                      href={href}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={ariaLabel}
                      class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-text-secondary hover:text-text-primary hover:bg-white/8 border border-white/10 hover:border-white/20 transition-all duration-200"
                      set:html={icon}
                    />
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </div>

      <!-- Hero image -->
      <div
        id="hero-image"
        class="anim-fade-up flex-shrink-0 lg:w-[380px] xl:w-[420px] order-first lg:order-last"
        style="animation-delay: 150ms;"
      >
        <img
          src="/Fang_Daniel_114-PilotSF-1471%20-%20use.jpg"
          alt="Daniel Fang"
          class="rounded-2xl w-full aspect-[3/4] object-cover shadow-2xl shadow-black/40"
          width="420"
          height="560"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-particle-mask {
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 100%);
  }

  /* Hidden by CSS before JS runs — prevents the paint→hide flash.
     GSAP animates these to opacity:1. The noscript block below
     overrides this for users with JS disabled. */
  #hero-eyebrow,
  #hero-headline,
  #hero-subtext,
  #hero-actions,
  #hero-image {
    opacity: 0;
  }
</style>

<noscript>
  <style>
    #hero-eyebrow,
    #hero-headline,
    #hero-subtext,
    #hero-actions,
    #hero-image {
      opacity: 1 !important;
    }
  </style>
</noscript>

<script>
  import { gsap } from "gsap";

  const HERO_IDS = "#hero-eyebrow, #hero-headline, #hero-subtext, #hero-actions, #hero-image";

  function initHero() {
    const hero = document.getElementById("hero");
    if (!hero) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (prefersReducedMotion) {
      // Skip animation but ensure elements are visible (CSS hides them by default)
      gsap.set(HERO_IDS, { opacity: 1, y: 0 });
      return;
    }

    // CSS already sets opacity:0 on these elements before first paint so there
    // is no flash. gsap.set() locks in the starting y offsets synchronously,
    // then the timeline animates everything into place.
    gsap.set("#hero-eyebrow",    { y: 20 });
    gsap.set("#hero-headline",   { y: 30 });
    gsap.set("#hero-subtext",    { y: 24 });
    gsap.set("#hero-actions",    { y: 20 });
    gsap.set("#hero-image",      { y: 24 });

    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
    tl.to("#hero-eyebrow",    { opacity: 1, y: 0, duration: 0.7 })
      .to("#hero-headline",   { opacity: 1, y: 0, duration: 0.8 }, "-=0.4")
      .to("#hero-subtext",    { opacity: 1, y: 0, duration: 0.7 }, "-=0.5")
      .to("#hero-actions",    { opacity: 1, y: 0, duration: 0.6 }, "-=0.4")
      .to("#hero-image",      { opacity: 1, y: 0, duration: 0.8 }, "-=1.2");
  }

  let _heroFired = false;
  document.addEventListener("astro:page-load", () => {
    _heroFired = true;
    initHero();
  });
  requestAnimationFrame(() => {
    if (!_heroFired) initHero();
  });
</script>
