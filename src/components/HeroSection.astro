---
const socialLinks = [
  {
    label: "GitHub",
    href: "https://github.com/danielfang",
    ariaLabel: "GitHub profile (opens in new tab)",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/danielfang",
    ariaLabel: "LinkedIn profile (opens in new tab)",
  },
  {
    label: "X",
    href: "https://twitter.com/danielfang",
    ariaLabel: "X / Twitter profile (opens in new tab)",
  },
];
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden"
  aria-label="Introduction"
>
  <!-- Subtle background grid -->
  <div class="absolute inset-0 bg-grid-pattern opacity-[0.03] pointer-events-none" aria-hidden="true" />

  <!-- Accent glow -->
  <div
    class="absolute top-1/3 left-1/4 w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(108,99,255,0.06) 0%, transparent 70%); transform: translate(-50%, -50%);"
    aria-hidden="true"
  />

  <div class="container-content relative z-10 pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-4xl">
      <!-- Eyebrow -->
      <div id="hero-eyebrow" class="anim-fade-up mb-6 flex items-center gap-3">
        <span class="accent-line" aria-hidden="true" />
        <span class="text-sm font-medium tracking-widest text-accent uppercase">
          Frontend Engineer
        </span>
      </div>

      <!-- Headline -->
      <h1
        id="hero-headline"
        class="anim-fade-up font-display text-display-xl font-bold text-text-primary text-balance mb-6"
        style="animation-delay: 100ms;"
      >
        Building things
        <br />
        <em class="not-italic gradient-text">worth experiencing.</em>
      </h1>

      <!-- Subtext -->
      <p
        id="hero-subtext"
        class="anim-fade-up text-lg md:text-xl text-text-secondary max-w-lg leading-relaxed mb-10"
        style="animation-delay: 200ms;"
      >
        I design and engineer high-quality web experiences — from expressive
        interfaces to the systems that power them.
      </p>

      <!-- CTAs + Social links -->
      <div
        id="hero-actions"
        class="anim-fade-up flex flex-wrap items-center gap-6"
        style="animation-delay: 300ms;"
      >
        <a
          href="/works"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-white font-semibold text-sm tracking-wide hover:bg-accent-hover transition-all duration-200 ease-out-expo hover:-translate-y-px hover:shadow-lg hover:shadow-accent/20"
        >
          View Works
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>

        <nav aria-label="Social media links">
          <ul class="flex items-center gap-4" role="list">
            {
              socialLinks.map(({ label, href, ariaLabel }) => (
                <li>
                  <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={ariaLabel}
                    class="text-sm text-text-secondary hover:text-text-primary transition-colors duration-200 relative group"
                  >
                    {label}
                    <span class="absolute -bottom-0.5 left-0 h-px w-0 bg-accent transition-all duration-300 ease-out-expo group-hover:w-full" aria-hidden="true" />
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    id="hero-scroll-cue"
    class="anim-fade-in absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
    style="animation-delay: 800ms;"
    aria-hidden="true"
  >
    <span class="text-xs tracking-widest text-text-muted uppercase">Scroll</span>
    <div class="w-px h-10 scroll-line bg-border relative overflow-hidden">
      <span class="scroll-shimmer absolute inset-0 bg-gradient-to-b from-transparent via-accent to-transparent" />
    </div>
  </div>
</section>

<style>
  .bg-grid-pattern {
    background-image:
      linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .scroll-shimmer {
    animation: shimmerDown 2s ease-in-out infinite;
  }

  @keyframes shimmerDown {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
</style>

<script>
  import { gsap } from "gsap";

  function initHero() {
    const hero = document.getElementById("hero");
    if (!hero) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!prefersReducedMotion) {
      // Staggered entrance — fromTo sets initial state programmatically so
      // elements are always visible if this function doesn't run (no CSS hiding).
      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
      tl.fromTo("#hero-eyebrow",    { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7 })
        .fromTo("#hero-headline",   { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8 }, "-=0.4")
        .fromTo("#hero-subtext",    { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.7 }, "-=0.5")
        .fromTo("#hero-actions",    { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6 }, "-=0.4")
        .fromTo("#hero-scroll-cue", { opacity: 0 },        { opacity: 1, duration: 0.8 },       "-=0.1");
    }
    // Reduced-motion: elements are visible by default (no CSS opacity:0)
  }

  let _heroFired = false;
  document.addEventListener("astro:page-load", () => {
    _heroFired = true;
    initHero();
  });
  requestAnimationFrame(() => {
    if (!_heroFired) initHero();
  });
</script>
