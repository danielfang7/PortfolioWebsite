---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/HeroSection.astro";
import WorksCarousel from "@/components/WorksCarousel.astro";
import { GitHubActivity, fetchGitHubEvents } from "@/components/GitHubActivity";

const githubEvents = await fetchGitHubEvents();
---

<BaseLayout
  title="Daniel Fang — Founder, Engineer, Investor"
  description="Founder and engineer building thoughtful digital experiences. Showcasing creative projects, investment activity, and written content."
>
  <HeroSection />
  <!-- Scroll cue: sits in the gap between hero and works on all viewports -->
  <section
    id="hero-scroll-cue-wrapper"
    class="flex justify-center items-center py-3 md:py-4"
    aria-hidden="true"
  >
    <div
      id="hero-scroll-cue"
      class="hero-scroll-cue flex flex-col items-center gap-2"
    >
      <span class="text-xs tracking-widest text-text-muted uppercase">Scroll</span>
      <div class="w-px h-10 scroll-line bg-border relative overflow-hidden">
        <span class="scroll-shimmer absolute inset-0 bg-gradient-to-b from-transparent via-accent to-transparent" />
      </div>
    </div>
  </section>
  <WorksCarousel />

  <!-- ── GitHub activity ─────────────────────────────────────────────── -->
  <section
    id="github-activity"
    class="container-content pb-10 md:pb-14"
    aria-labelledby="github-activity-heading"
  >
    <div class="border-t border-border-subtle pt-16">
      <div class="flex items-center gap-3 mb-3">
        <span class="accent-line" aria-hidden="true" />
        <span class="text-sm font-medium tracking-widest text-accent uppercase">Active Building</span>
      </div>
      <div class="flex items-end justify-between mb-8 gap-4">
        <h2
          id="github-activity-heading"
          class="font-display text-2xl sm:text-3xl font-bold text-text-primary leading-tight"
        >
          Recent Activity
        </h2>
        <p class="text-sm text-text-muted hidden sm:block">Live from GitHub</p>
      </div>

      <GitHubActivity initialEvents={githubEvents} client:visible />
    </div>
  </section>
</BaseLayout>
