---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const cardPosts = allPosts.slice(0, 3);

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function slug(id: string) {
  return id.replace(/\.(md|mdx)$/, "");
}
---

<BaseLayout
  title="Blog"
  description="Writing on engineering, design systems, startups, and building things on the internet."
>
  <div class="pt-32 section-padding">
    <div class="container-content max-w-6xl">
      <!-- Section header -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="accent-line" aria-hidden="true" />
          <span class="text-sm font-medium tracking-widest text-accent uppercase">Writing</span>
        </div>
        <h1 class="font-display text-display-lg font-bold text-text-primary mb-4">
          Blog
        </h1>
        <p class="text-lg text-text-secondary leading-relaxed">
          Thoughts on engineering, design, and building products. Occasionally,
          something more personal.
        </p>
      </div>

      {allPosts.length === 0 ? (
        <div class="rounded-2xl border border-border-subtle p-16 text-center">
          <p class="text-text-muted text-sm">Posts coming soon.</p>
        </div>
      ) : (
        <>
          <!-- Latest 3 posts as cards -->
          {cardPosts.length > 0 && (
            <section class="mb-20" aria-label="Latest posts">
              <div class="grid gap-6 md:grid-cols-3">
                {cardPosts.map((post) => (
                  <a
                    href={`/blog/${slug(post.id)}`}
                    class="group flex flex-col p-6 rounded-2xl border border-border-subtle bg-bg-surface hover:border-border hover:-translate-y-0.5 transition-all duration-300 ease-out-expo"
                  >
                    <h2 class="font-display font-semibold text-lg text-text-primary group-hover:text-accent transition-colors duration-200 mb-2">
                      {post.data.title}
                    </h2>
                    <p class="text-sm text-text-secondary line-clamp-2 flex-1">
                      {post.data.excerpt}
                    </p>
                    <span class="inline-flex items-center gap-2 text-sm text-accent font-medium mt-4 group-hover:gap-3 transition-all duration-300 ease-out-expo">
                      Read more
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </span>
                  </a>
                ))}
              </div>
            </section>
          )}

          <!-- All posts in list with tag filter -->
          <section aria-label="All articles">
            <h2 class="font-display text-display-md font-bold text-text-primary mb-8">
              Latest Posts
            </h2>

            <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
              <!-- Tag filter sidebar -->
              <aside class="lg:w-48 shrink-0" aria-label="Filter by tag">
                <nav class="flex flex-wrap lg:flex-col gap-2 lg:gap-1">
                  <button
                    type="button"
                    class="blog-tag-btn active text-left text-sm font-medium py-2 pl-3 -ml-px border-l-2 border-accent text-text-primary hover:text-accent transition-colors duration-200"
                    data-tag="__all__"
                    aria-pressed="true"
                  >
                    All blogs
                  </button>
                  {allTags.map((tag) => (
                    <button
                      type="button"
                      class="blog-tag-btn text-left text-sm font-medium py-2 pl-3 -ml-px border-l-2 border-transparent text-text-secondary hover:text-text-primary transition-colors duration-200"
                      data-tag={tag}
                      aria-pressed="false"
                    >
                      {tag}
                    </button>
                  ))}
                </nav>
              </aside>

              <!-- Article list -->
              <div class="flex-1 min-w-0">
                <ul class="divide-y divide-border-subtle" role="list" id="blog-article-list">
                  {allPosts.map((post, i) => (
                    <li
                      class="blog-post-item anim-fade-up"
                      style={`--delay: ${i * 60}ms`}
                      data-tags={JSON.stringify(post.data.tags)}
                    >
                      <a
                        href={`/blog/${slug(post.id)}`}
                        class="group flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 py-6 hover:translate-x-2 transition-all duration-300 ease-out-expo"
                      >
                        <div class="min-w-0 flex-1">
                          <h3 class="font-display font-semibold text-lg text-text-primary group-hover:text-accent transition-colors duration-200">
                            {post.data.title}
                          </h3>
                          <p class="text-sm text-text-secondary line-clamp-2 mt-1">
                            {post.data.excerpt}
                          </p>
                        </div>
                        <div class="flex items-center gap-4 shrink-0 sm:ml-6">
                          <time class="text-xs text-text-muted" datetime={post.data.date.toISOString()}>
                            {formatDate(post.data.date)}
                          </time>
                          {post.data.readingTime && (
                            <span class="text-xs text-text-muted">{post.data.readingTime}</span>
                          )}
                          <svg
                            class="shrink-0 text-text-muted opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all duration-300 ease-out-expo"
                            width="18"
                            height="18"
                            viewBox="0 0 16 16"
                            fill="none"
                            aria-hidden="true"
                          >
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </section>
        </>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initBlogAnimations() {
    const items = document.querySelectorAll(".blog-post-item");
    if (!items.length) return;

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    items.forEach((el) => {
      el.style.opacity = "1";
      el.style.transform = "none";
    });

    if (prefersReducedMotion) return;

    ScrollTrigger.getAll().forEach((t) => {
      const trigger = t.trigger;
      if (trigger?.classList?.contains("blog-post-item")) t.kill();
    });

    items.forEach((item, i) => {
      gsap.fromTo(
        item,
        { opacity: 0, x: -12 },
        {
          opacity: 1,
          x: 0,
          duration: 0.55,
          delay: i * 0.06,
          ease: "power3.out",
          scrollTrigger: {
            trigger: item,
            start: "top 90%",
            toggleActions: "play none none none",
          },
        }
      );
    });

    ScrollTrigger.refresh();
  }

  function initTagFilter() {
    const buttons = document.querySelectorAll(".blog-tag-btn");
    const items = document.querySelectorAll(".blog-post-item");

    if (!buttons.length || !items.length) return;

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tag = btn.getAttribute("data-tag");

        buttons.forEach((b) => {
          b.classList.remove("active", "text-text-primary", "border-accent");
          b.classList.add("text-text-secondary", "border-transparent");
          b.setAttribute("aria-pressed", "false");
        });
        btn.classList.add("active", "text-text-primary", "border-accent");
        btn.classList.remove("text-text-secondary", "border-transparent");
        btn.setAttribute("aria-pressed", "true");

        items.forEach((item) => {
          const tagsJson = item.getAttribute("data-tags");
          const tags = tagsJson ? JSON.parse(tagsJson) : [];
          const matches = tag === "__all__" || tags.includes(tag);
          item.style.display = matches ? "" : "none";
        });
      });
    });
  }

  let _blogInitFired = false;

  document.addEventListener("astro:page-load", () => {
    _blogInitFired = true;
    initBlogAnimations();
    initTagFilter();
  });

  requestAnimationFrame(() => {
    if (!_blogInitFired) {
      initBlogAnimations();
      initTagFilter();
    }
  });

  document.addEventListener("astro:after-swap", () => {
    initBlogAnimations();
    initTagFilter();
  });
</script>
