---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Museum from "@/components/museum/Museum";
import LabGrid from "@/components/LabGrid.astro";
import { experiments } from "@/data/experiments";
import { getCollection } from "astro:content";

const works = (await getCollection("works"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 5)
  .map((w) => ({
    slug: w.id.replace(/\.(md|mdx)$/, ""),
    title: w.data.title,
  }));
---

<BaseLayout
  title="Lab"
  description="Self-contained front-end experiments: shader effects, generative art, and novel UI patterns."
>
  <section class="section-padding" aria-labelledby="lab-heading">
    <div class="container-content">
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
          <span class="accent-line" aria-hidden="true" />
          <span class="text-sm font-medium tracking-widest text-accent uppercase">
            Experiments
          </span>
        </div>
        <h1
          id="lab-heading"
          class="font-display text-display-lg font-bold text-text-primary mb-4"
        >
          Lab
        </h1>
        <p class="text-text-secondary max-w-xl leading-relaxed">
          Walk through the museum. Paintings are experiments, computer desks
          are works. Stand in front of anything glowing cyan and press E to
          interact.
        </p>
      </div>

      <div data-lab-pane="museum">
        <Museum client:only="react" experiments={experiments} works={works} />
      </div>

      <div data-lab-pane="list" hidden>
        <div class="flex justify-end mb-6">
          <button
            type="button"
            id="lab-back-to-museum"
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-border text-sm text-text-primary hover:border-accent hover:text-accent transition-colors"
          >
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path
                d="M10 4L6 8l4 4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            Museum view
          </button>
        </div>
        <LabGrid experiments={experiments} />
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function initLabView() {
    const museumPane = document.querySelector<HTMLElement>(
      '[data-lab-pane="museum"]',
    );
    const listPane = document.querySelector<HTMLElement>(
      '[data-lab-pane="list"]',
    );
    const backBtn = document.getElementById("lab-back-to-museum");
    if (!museumPane || !listPane) return;

    function setView(mode: "museum" | "list") {
      if (!museumPane || !listPane) return;
      if (mode === "list") {
        museumPane.hidden = true;
        listPane.hidden = false;
      } else {
        museumPane.hidden = false;
        listPane.hidden = true;
      }
      try {
        sessionStorage.setItem("labView", mode);
      } catch {
        /* storage blocked — fall through */
      }
    }

    window.__setLabView = setView;
    backBtn?.addEventListener("click", () => setView("museum"));

    try {
      if (sessionStorage.getItem("labView") === "list") setView("list");
    } catch {
      /* storage blocked — default museum view */
    }
  }

  document.addEventListener("astro:page-load", initLabView);
</script>
